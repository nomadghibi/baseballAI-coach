# App
APP_ENV=local
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:8000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/baseball_ai

# Auth
JWT_SECRET=replace_me_with_long_random_secret
JWT_EXPIRES_MINUTES=1440
COOKIE_SECURE=false

# Storage
STORAGE_PROVIDER=local
STORAGE_BUCKET=baseball-ai-dev
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_REGION=auto
SIGNED_URL_EXPIRES_SECONDS=900

# Upload limits
MAX_VIDEO_SIZE_MB=100
MAX_VIDEO_DURATION_SECONDS=30
ALLOWED_VIDEO_TYPES=video/mp4,video/quicktime

# Analysis
ANALYSIS_SAMPLE_FPS=15
ANALYSIS_MIN_QUALITY_SCORE=40
USE_BACKGROUND_TASKS=true
REDIS_URL=

# CORS
CORS_ORIGINS=http://localhost:3000
