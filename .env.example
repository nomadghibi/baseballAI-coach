# Root env — copy values into apps/api/.env and apps/web/.env.local

# Database (matches docker-compose defaults)
DATABASE_URL=postgresql://baseballai:baseballai_dev@localhost:5432/baseballai

# API
API_URL=http://localhost:8000

# Auth — change in production
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# Storage (Cloudflare R2 / S3-compatible — fill in for production)
STORAGE_BUCKET=
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
